# ============================================
# LLARS Development Environment Configuration
# ============================================
# This file contains settings optimized for local development
# Copy to .env and customize as needed

PROJECT_STATE=development
REMOVE_VOLUMES=False

# ============================================
# Central Project URL Configuration
# ============================================
PROJECT_HOST=localhost

# ============================================
# MariaDB Configuration (LLARS Database)
# ============================================
MYSQL_ROOT_PASSWORD=dev_root_password_change_me
MYSQL_DATABASE=database_llars
MYSQL_USER=dev_user
MYSQL_PASSWORD=dev_password_change_me

# ============================================
# Flask Configuration
# ============================================
FLASK_ENV=development
FLASK_DEBUG=True

# ============================================
# API Keys (Development - Use Test Keys)
# ============================================
# SECURITY: Never commit real API keys!
OPENAI_API_KEY=sk-test-placeholder-replace-with-real-key

# LiteLLM Proxy Configuration (TH Nürnberg)
LITELLM_API_KEY=sk-RgzbaiE9HM8w0I5IWgZz6g
LITELLM_BASE_URL=https://kiz1.in.ohmportal.de/llmproxy/v1

# ============================================
# Keycloak Configuration (Development)
# ============================================
# Database
KEYCLOAK_DB_NAME=keycloak_dev
KEYCLOAK_DB_USER=keycloak_dev
KEYCLOAK_DB_PASSWORD=dev_keycloak_db_password

# Admin Credentials (Development only - weak is OK)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin123

# URLs (Internal Docker network)
KEYCLOAK_URL=http://keycloak-service:8080
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_REALM=llars

# Clients
KEYCLOAK_FRONTEND_CLIENT_ID=llars-frontend
KEYCLOAK_BACKEND_CLIENT_ID=llars-backend
KEYCLOAK_BACKEND_CLIENT_SECRET=dev-backend-secret-not-for-production

# SSL/TLS (Development: disabled for easier testing)
KEYCLOAK_SSL_REQUIRED=none
KEYCLOAK_HTTPS_ENABLED=false

# ============================================
# Development Features
# ============================================
START_SEEDER=False

# ============================================
# Port Configuration (Development)
# ============================================
# All ports in 55000 range to avoid conflicts
# External ports (exposed to host)
NGINX_EXTERNAL_PORT=55080
FLASK_EXTERNAL_PORT=55081
FRONTEND_EXTERNAL_PORT=55173
DB_EXTERNAL_PORT=55306
KEYCLOAK_EXTERNAL_PORT=55090
YJS_EXTERNAL_PORT=55082
MKDOCS_EXTERNAL_PORT=55800

# Internal ports (container ports)
NGINX_INTERNAL_PORT=80
FLASK_INTERNAL_PORT=8081
FRONTEND_INTERNAL_PORT=5173
DB_INTERNAL_PORT=3306
KEYCLOAK_INTERNAL_PORT=8080
KEYCLOAK_DB_INTERNAL_PORT=5432
YJS_INTERNAL_PORT=8082

# ============================================
# CORS Configuration (Development)
# ============================================
# Permissive CORS for local development
ALLOWED_ORIGINS=http://localhost:55080,http://localhost:55173,http://127.0.0.1:55080,http://127.0.0.1:55173,http://localhost,http://127.0.0.1

# ============================================
# Development-Specific Settings
# ============================================
# Email verification disabled for easier testing
KEYCLOAK_VERIFY_EMAIL=false
KEYCLOAK_REGISTRATION_ALLOWED=true

# Brute force protection (relaxed for development)
KEYCLOAK_BRUTE_FORCE_PROTECTED=true
KEYCLOAK_FAILURE_FACTOR=10
KEYCLOAK_MAX_FAILURE_WAIT_SECONDS=300

# Token lifespans (longer for development)
KEYCLOAK_ACCESS_TOKEN_LIFESPAN=1800
KEYCLOAK_SSO_SESSION_IDLE_TIMEOUT=36000
KEYCLOAK_SSO_SESSION_MAX_LIFESPAN=36000
