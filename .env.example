# Central Project URL Configuration
# All external URLs are derived from this base
PROJECT_HOST=localhost

# MariaDB_Feature
MYSQL_ROOT_PASSWORD=root_password_feature
MYSQL_DATABASE=database_llars
MYSQL_USER=user_feature
MYSQL_PASSWORD=password_feature
FLASK_ENV=development

OPENAI_API_KEY=...

PROXY_REMOTE_USER=...

#START_SEEDER=true

# Derived URLs (constructed in docker-compose.yml from PROJECT_HOST and ports)
# BASE_URL = http://${PROJECT_HOST}:${NGINX_EXTERNAL_PORT}
# MKDOCS_URL = http://${PROJECT_HOST}:${MKDOCS_EXTERNAL_PORT}
# KEYCLOAK_EXTERNAL_URL = http://${PROJECT_HOST}:${KEYCLOAK_EXTERNAL_PORT}

VUE_APP_TIMEOUT=5000
VUE_APP_TOKEN_KEY="token"
VUE_APP_TITLE="LLars App"

### DANGER ZONE ###
# Remove Volumes at start. Handle with Caution!
REMOVE_VOLUMES=True