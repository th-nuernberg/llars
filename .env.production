# ============================================
# LLARS Production Environment Configuration
# ============================================
# This file contains settings optimized for production deployment
# SECURITY: Never commit this file with real secrets!

PROJECT_STATE=production
REMOVE_VOLUMES=False

# ============================================
# Central Project URL Configuration
# ============================================
# IMPORTANT: Replace with your actual production domain
PROJECT_HOST=llars.yourdomain.com

# ============================================
# MariaDB Configuration (LLARS Database)
# ============================================
# SECURITY: Generate strong random passwords (32+ chars)
# Example: openssl rand -base64 32
MYSQL_ROOT_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD_32_CHARS_MIN
MYSQL_DATABASE=database_llars
MYSQL_USER=llars_prod_user
MYSQL_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD_32_CHARS_MIN

# ============================================
# Flask Configuration
# ============================================
FLASK_ENV=production
FLASK_DEBUG=False

# ============================================
# API Keys (Production)
# ============================================
# SECURITY: Use environment-specific secrets management (AWS Secrets Manager, Vault, etc.)
OPENAI_API_KEY=CHANGE_ME_REAL_OPENAI_KEY

# LiteLLM Proxy Configuration
LITELLM_API_KEY=CHANGE_ME_REAL_LITELLM_KEY
LITELLM_BASE_URL=https://kiz1.in.ohmportal.de/llmproxy/v1

# ============================================
# Keycloak Configuration (Production)
# ============================================
# Database
KEYCLOAK_DB_NAME=keycloak_prod
KEYCLOAK_DB_USER=keycloak_prod
# SECURITY: Generate with: openssl rand -base64 32
KEYCLOAK_DB_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD_32_CHARS_MIN

# Admin Credentials
# SECURITY: Use strong password (16+ chars, mixed case, numbers, symbols)
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD_16_CHARS_MIN

# URLs
# Internal Docker network URL
KEYCLOAK_URL=http://keycloak-service:8080
# External hostname (must match SSL certificate)
KEYCLOAK_HOSTNAME=llars.yourdomain.com
KEYCLOAK_REALM=llars

# Clients
KEYCLOAK_FRONTEND_CLIENT_ID=llars-frontend
KEYCLOAK_BACKEND_CLIENT_ID=llars-backend
# SECURITY: Generate with: openssl rand -base64 48
KEYCLOAK_BACKEND_CLIENT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET_48_CHARS_MIN

# SSL/TLS (Production: REQUIRED)
KEYCLOAK_SSL_REQUIRED=all
KEYCLOAK_HTTPS_ENABLED=true
# Path to SSL certificates (mounted as volume)
KEYCLOAK_HTTPS_CERTIFICATE_FILE=/opt/keycloak/certs/cert.pem
KEYCLOAK_HTTPS_CERTIFICATE_KEY_FILE=/opt/keycloak/certs/key.pem

# ============================================
# Production Features
# ============================================
START_SEEDER=False

# ============================================
# Port Configuration (Production)
# ============================================
# SECURITY: Only expose nginx on 443 (HTTPS)
# Internal services should NOT be exposed to host

# External ports (only nginx exposed)
NGINX_EXTERNAL_PORT=443
NGINX_HTTP_PORT=80

# All other ports are INTERNAL ONLY (no host exposure)
# These are used only for inter-container communication
FLASK_INTERNAL_PORT=8081
FRONTEND_INTERNAL_PORT=5173
DB_INTERNAL_PORT=3306
KEYCLOAK_INTERNAL_PORT=8080
KEYCLOAK_DB_INTERNAL_PORT=5432
YJS_INTERNAL_PORT=8082

# ============================================
# CORS Configuration (Production)
# ============================================
# SECURITY: Specify exact allowed origins (NO wildcards!)
ALLOWED_ORIGINS=https://llars.yourdomain.com

# ============================================
# Production-Specific Settings
# ============================================
# Email verification REQUIRED for production
KEYCLOAK_VERIFY_EMAIL=true
KEYCLOAK_REGISTRATION_ALLOWED=false

# SMTP Configuration (for email verification)
KEYCLOAK_SMTP_HOST=smtp.yourdomain.com
KEYCLOAK_SMTP_PORT=587
KEYCLOAK_SMTP_FROM=noreply@llars.yourdomain.com
KEYCLOAK_SMTP_USER=CHANGE_ME_SMTP_USERNAME
KEYCLOAK_SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
KEYCLOAK_SMTP_SSL=true
KEYCLOAK_SMTP_STARTTLS=true

# Brute force protection (strict)
KEYCLOAK_BRUTE_FORCE_PROTECTED=true
KEYCLOAK_FAILURE_FACTOR=5
KEYCLOAK_MAX_FAILURE_WAIT_SECONDS=900

# Token lifespans (short for security)
KEYCLOAK_ACCESS_TOKEN_LIFESPAN=300
KEYCLOAK_SSO_SESSION_IDLE_TIMEOUT=1800
KEYCLOAK_SSO_SESSION_MAX_LIFESPAN=36000

# ============================================
# Database SSL/TLS (Production)
# ============================================
# Enable TLS for database connections
MYSQL_SSL_MODE=REQUIRED
POSTGRES_SSL_MODE=require

# ============================================
# Monitoring & Logging (Production)
# ============================================
# Log level
LOG_LEVEL=WARNING

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# ============================================
# Security Headers (Production)
# ============================================
# Strict Transport Security (HSTS)
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true

# ============================================
# IMPORTANT PRODUCTION CHECKLIST
# ============================================
# Before deploying to production:
# [ ] Change ALL passwords and secrets above
# [ ] Configure SSL certificates in docker/nginx/certs/
# [ ] Set PROJECT_HOST to your actual domain
# [ ] Configure SMTP for email verification
# [ ] Set up backup strategy for databases
# [ ] Configure monitoring (Prometheus, Grafana)
# [ ] Set up log aggregation (ELK Stack)
# [ ] Review and test all security settings
# [ ] Perform penetration testing
# [ ] Set up Web Application Firewall (WAF)
# [ ] Configure automatic SSL certificate renewal (Let's Encrypt)
