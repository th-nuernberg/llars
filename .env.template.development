# ============================================
# LLARS Environment Configuration - DEVELOPMENT
# ============================================
#
# Setup:
#   cp .env.template.development .env
#   ./start_llars.sh
#
# Ziel: .env klein halten. Docker Compose hat sinnvolle Defaults und
# App-Settings (z. B. Analytics/Tracking) sind im Admin-Panel konfigurierbar.
# ============================================

# Mode
PROJECT_STATE=development

# Main entry URL (protocol + host + port)
PROJECT_URL=http://localhost:55080

# DANGER ZONE: set True once to remove LLARS data on next start!
REMOVE_LLARS_VOLUMES=False
# DANGER ZONE: removes ALL LLARS containers, images, volumes and build cache
PRUNE_LLARS_SYSTEM=False

# Optional: additional demo seeders
START_SEEDER=False

# Optional: override host ports (defaults shown)
#NGINX_EXTERNAL_PORT=55080
#AUTHENTIK_EXTERNAL_PORT=55095
#DB_EXTERNAL_PORT=55306
#MKDOCS_EXTERNAL_PORT=55800

# ============================================
# Secrets / external integrations (optional in dev)
# ============================================

# Debug API key (OnCoCo debug endpoints). If empty, a random key is generated on first start.
SYSTEM_ADMIN_API_KEY=

# LLARS Admin Password (for Authentik users)
# In development: all test users (admin, researcher, viewer) use this password
LLARS_ADMIN_PASSWORD=admin123

# Required for /auth/register_admin endpoint (set a UUID if you use it)
#ADMIN_REGISTRATION_KEY=

# LLM providers (optional)
OPENAI_API_KEY=
LITELLM_BASE_URL=https://kiz1.in.ohmportal.de/llmproxy/v1
LITELLM_API_KEY=

# LLM-as-Judge GitLab token (optional)
KIA_GITLAB_TOKEN=

# Zotero OAuth (optional - for LaTeX Collab Zotero integration)
# Register at: https://www.zotero.org/oauth/apps
# Callback URL: ${PROJECT_URL}/api/zotero/connect/oauth/callback
ZOTERO_CLIENT_KEY=
ZOTERO_CLIENT_SECRET=

# ============================================
# Rare overrides (defaults live in docker-compose.yml)
# ============================================

# MariaDB (LLARS)
#MYSQL_ROOT_PASSWORD=dev_root_password_change_me
#MYSQL_DATABASE=database_llars
#MYSQL_USER=dev_user
#MYSQL_PASSWORD=dev_password_change_me

# Authentik (OIDC provider)
#AUTHENTIK_SECRET_KEY=dev-authentik-secret-key-change-me-please-64-chars-minimum-xxxxxxxx
#AUTHENTIK_DB_NAME=authentik_dev
#AUTHENTIK_DB_USER=authentik_dev
#AUTHENTIK_DB_PASSWORD=dev_authentik_db_password
#AUTHENTIK_PUBLIC_URL=http://localhost:55095
#AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
#AUTHENTIK_BOOTSTRAP_PASSWORD=admin123
#AUTHENTIK_BACKEND_CLIENT_SECRET=llars-backend-secret-change-in-production

# Matomo (Analytics)
# Matomo UI: http://localhost:55080/analytics/
#MATOMO_MYSQL_ROOT_PASSWORD=matomo_root_password_change_me
#MATOMO_MYSQL_DATABASE=matomo
#MATOMO_MYSQL_USER=matomo
#MATOMO_MYSQL_PASSWORD=matomo_password_change_me
#MATOMO_SUPERUSER_LOGIN=admin
#MATOMO_SUPERUSER_PASSWORD=admin123
#MATOMO_SUPERUSER_EMAIL=admin@example.com
#MATOMO_SITE_NAME=LLARS
#MATOMO_SITE_URL=http://localhost:55080
#MATOMO_TRUSTED_HOST=localhost:55080
#AUTHENTIK_MATOMO_CLIENT_SECRET=llars-matomo-secret-change-in-production

# Authentik Admin API Token (for user management from Admin Panel)
# This token is auto-created by authentik-init and allows LLARS to create users in Authentik
AUTHENTIK_API_TOKEN=llars-dev-api-token-do-not-use-in-production
