# ============================================
# LLARS Environment Configuration - DEVELOPMENT
# ============================================
#
# USAGE:
#   cp .env.template.development .env
#
# This template is optimized for LOCAL DEVELOPMENT:
# - All ports exposed for debugging
# - Debug modes enabled
# - Hot-reload enabled
# - Local URLs (localhost)
# ============================================

# Project Mode
PROJECT_STATE=development

# DANGER ZONE: Volume Management
# Set to True to DELETE ALL DATA on next start!
REMOVE_VOLUMES=False

# ============================================
# Host Configuration
# ============================================
PROJECT_HOST=localhost

# ============================================
# MariaDB Configuration
# ============================================
MYSQL_ROOT_PASSWORD=dev_root_password_change_me
MYSQL_DATABASE=database_llars
MYSQL_USER=dev_user
MYSQL_PASSWORD=dev_password_change_me

# Flask Environment
FLASK_ENV=development

# ============================================
# API Keys - CHANGE THESE IN PRODUCTION!
# ============================================

# System Admin API Key (for debug endpoints)
SYSTEM_ADMIN_API_KEY=llars-admin-key-change-in-production-12345

# OpenAI API Key (optional - for direct OpenAI access)
OPENAI_API_KEY=sk-your-openai-key-here

# LiteLLM Proxy (TH Nuernberg internal)
LITELLM_API_KEY=sk-your-litellm-key-here
LITELLM_BASE_URL=https://kiz1.in.ohmportal.de/llmproxy/v1

# KIA GitLab Token (for LLM-as-Judge data sync)
# Get token from: https://git.informatik.fh-nuernberg.de/-/user_settings/personal_access_tokens
# Required scopes: read_repository
KIA_GITLAB_TOKEN=glpat-your-token-here

# ============================================
# Authentik Configuration (Identity Provider)
# ============================================
# Django SECRET_KEY - must be 50+ characters with high entropy
# For development, a pre-generated key is provided below
# For production, generate a new one with: openssl rand -base64 64
AUTHENTIK_SECRET_KEY=dev-
AUTHENTIK_DB_NAME=authentik_dev
AUTHENTIK_DB_USER=authentik_dev
AUTHENTIK_DB_PASSWORD=dev_authentik_db_password

# Bootstrap Admin (created on first start)
AUTHENTIK_BOOTSTRAP_EMAIL=admin@example.com
AUTHENTIK_BOOTSTRAP_PASSWORD=admin123

# OAuth2 Client Configuration
AUTHENTIK_FRONTEND_CLIENT_ID=llars-frontend
AUTHENTIK_BACKEND_CLIENT_ID=llars-backend
AUTHENTIK_BACKEND_CLIENT_SECRET=llars-backend-secret-change-in-production
AUTHENTIK_ISSUER_URL=http://authentik-server:9000/application/o/llars-backend/

# ============================================
# Optional Features
# ============================================
START_SEEDER=False

# ============================================
# Port Configuration - DEVELOPMENT
# ============================================
# All ports in 55000 range to avoid conflicts with other projects
#
# External ports (exposed to host for debugging)
NGINX_EXTERNAL_PORT=55080
FLASK_EXTERNAL_PORT=55081
FRONTEND_EXTERNAL_PORT=55173
DB_EXTERNAL_PORT=55306
AUTHENTIK_EXTERNAL_PORT=55095
YJS_EXTERNAL_PORT=55082
MKDOCS_EXTERNAL_PORT=55800

# Internal ports (container-to-container, rarely change)
NGINX_INTERNAL_PORT=80
FLASK_INTERNAL_PORT=8081
FRONTEND_INTERNAL_PORT=5173
DB_INTERNAL_PORT=3306
AUTHENTIK_INTERNAL_PORT=9000
AUTHENTIK_DB_INTERNAL_PORT=5432
YJS_INTERNAL_PORT=8082

# ============================================
# Development URLs (after start)
# ============================================
# Frontend:    http://localhost:55080
# Backend API: http://localhost:55080/api
# Authentik:   http://localhost:55095
# Database:    localhost:55306 (MySQL client)
# Docs:        http://localhost:55800
# ============================================
