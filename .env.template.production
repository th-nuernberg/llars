# ============================================
# LLARS Environment Configuration - PRODUCTION
# ============================================
#
# Setup:
#   cp .env.template.production .env
#   ./start_llars.sh prod
#
# Hinweis:
# - PROJECT_URL ohne trailing slash setzen (kein .../ am Ende)
# - Interne Ports & Client-IDs sind Invarianten und werden nicht über .env konfiguriert.
# - App-Settings (z. B. Analytics/Tracking) sind im Admin-Panel konfigurierbar.
# ============================================

# Mode
PROJECT_STATE=production

# Main entry URL (protocol + domain, NO trailing slash)
PROJECT_URL=https://llars.your-domain.de

# DANGER ZONE: NEVER set to True in production unless you want to lose ALL DATA!
REMOVE_LLARS_VOLUMES=False
# DANGER ZONE: removes ALL LLARS containers, images, volumes and build cache
PRUNE_LLARS_SYSTEM=False

# Optional: additional demo seeders (usually False in production)
START_SEEDER=False

# ============================================
# MariaDB (LLARS) - REQUIRED
# ============================================
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD_32CHARS
MYSQL_DATABASE=database_llars
MYSQL_USER=llars_prod
MYSQL_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD_32CHARS

# ============================================
# Admin Keys - REQUIRED
# ============================================
# Generate with: openssl rand -hex 32
SYSTEM_ADMIN_API_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Generate with: python3 -c "import uuid; print(uuid.uuid4())"
ADMIN_REGISTRATION_KEY=CHANGE_ME_GENERATE_NEW_UUID_FOR_PRODUCTION

# LLARS Admin Password (for the single admin user in Authentik)
# Generate with: openssl rand -base64 24
# In production: ONLY the admin user is created (no researcher/evaluator)
LLARS_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD_24CHARS

# Flask Secret Key (required for session-based features like Zotero OAuth)
# Generate with: openssl rand -base64 32
FLASK_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32

# ============================================
# LLM Providers (optional)
# ============================================
OPENAI_API_KEY=
LITELLM_BASE_URL=https://kiz1.in.ohmportal.de/llmproxy/v1
LITELLM_API_KEY=
KIA_GITLAB_TOKEN=

# ============================================
# Zotero OAuth (optional - for LaTeX Collab)
# ============================================
# Register at: https://www.zotero.org/oauth/apps
# Callback URL: ${PROJECT_URL}/api/zotero/connect/oauth/callback
ZOTERO_CLIENT_KEY=
ZOTERO_CLIENT_SECRET=

# ============================================
# Authentik (OIDC Provider) - REQUIRED
# ============================================
# Generate with: openssl rand -base64 64  (>= 50 chars)
AUTHENTIK_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64_MINIMUM_50_CHARS

AUTHENTIK_DB_NAME=authentik_prod
AUTHENTIK_DB_USER=authentik_prod
AUTHENTIK_DB_PASSWORD=CHANGE_ME_STRONG_AUTHENTIK_DB_PASSWORD

# Public URL for Authentik (used for redirects)
# Example: https://llars.your-domain.de/authentik
AUTHENTIK_PUBLIC_URL=https://llars.your-domain.de/authentik

# Bootstrap admin (created on first start)
AUTHENTIK_BOOTSTRAP_EMAIL=admin@your-domain.de
AUTHENTIK_BOOTSTRAP_PASSWORD=CHANGE_ME_SECURE_ADMIN_PASSWORD

# Backend OAuth client secret (client id is invariant: llars-backend)
# Generate with: openssl rand -hex 32
AUTHENTIK_BACKEND_CLIENT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# ============================================
# Matomo (Analytics) - REQUIRED
# ============================================
# Matomo UI: https://<PROJECT_URL>/analytics/
MATOMO_MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_MATOMO_ROOT_PASSWORD_32CHARS
MATOMO_MYSQL_DATABASE=matomo
MATOMO_MYSQL_USER=matomo_prod
MATOMO_MYSQL_PASSWORD=CHANGE_ME_STRONG_MATOMO_DB_PASSWORD_32CHARS
MATOMO_DATABASE_TABLES_PREFIX=matomo_

# Matomo superuser (created on first start)
MATOMO_SUPERUSER_LOGIN=admin
MATOMO_SUPERUSER_PASSWORD=CHANGE_ME_STRONG_MATOMO_ADMIN_PASSWORD
MATOMO_SUPERUSER_EMAIL=admin@your-domain.de

# First tracked site (created on first start)
MATOMO_SITE_NAME=LLARS
MATOMO_SITE_URL=https://llars.your-domain.de
MATOMO_TRUSTED_HOST=llars.your-domain.de
MATOMO_ARCHIVE_URL=https://llars.your-domain.de/analytics/

# Matomo SSO (Authentik OIDC via RebelOIDC plugin)
MATOMO_OIDC_ENABLED=true
MATOMO_OIDC_FORCE_CONFIG=false

# Authentik OAuth2 client secret for Matomo (client id is invariant: llars-matomo)
AUTHENTIK_MATOMO_CLIENT_SECRET=CHANGE_ME_STRONG_MATOMO_OIDC_CLIENT_SECRET_32CHARS
