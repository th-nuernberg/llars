# ============================================
# LLARS Environment Configuration - PRODUCTION
# ============================================
#
# USAGE:
#   cp .env.template.production .env
#   # Then edit .env with your production secrets!
#
# This template is optimized for PRODUCTION DEPLOYMENT:
# - Minimal port exposure (only nginx:80/443)
# - Debug modes disabled
# - Strong secrets required
# - Real domain URLs
#
# SECURITY CHECKLIST:
#   [ ] Change ALL passwords and secrets below
#   [ ] Set real PROJECT_HOST domain
#   [ ] Configure SSL certificates
#   [ ] Review firewall rules
# ============================================

# Project Mode
PROJECT_STATE=production

# DANGER ZONE: Volume Management
# NEVER set to True in production unless you want to lose ALL DATA!
REMOVE_VOLUMES=False

# ============================================
# Host Configuration
# ============================================
# Set to your actual domain (without https://)
PROJECT_HOST=llars.your-domain.de

# ============================================
# MariaDB Configuration
# ============================================
# CHANGE THESE! Use strong, unique passwords
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD_32CHARS
MYSQL_DATABASE=database_llars
MYSQL_USER=llars_prod
MYSQL_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD_32CHARS

# Flask Environment
FLASK_ENV=production

# ============================================
# API Keys - PRODUCTION VALUES REQUIRED!
# ============================================

# System Admin API Key (generate with: openssl rand -hex 32)
SYSTEM_ADMIN_API_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Admin Registration Key (required for /auth/register_admin endpoint)
# CRITICAL: Generate a NEW secret for production!
# Command: python3 -c "import uuid; print(uuid.uuid4())"
ADMIN_REGISTRATION_KEY=CHANGE_ME_GENERATE_NEW_UUID_FOR_PRODUCTION

# OpenAI API Key (optional)
OPENAI_API_KEY=sk-your-production-openai-key

# LiteLLM Proxy (TH Nuernberg internal)
LITELLM_API_KEY=sk-your-production-litellm-key
LITELLM_BASE_URL=https://kiz1.in.ohmportal.de/llmproxy/v1

# KIA GitLab Token (for LLM-as-Judge data sync)
KIA_GITLAB_TOKEN=glpat-your-production-token

# ============================================
# Matomo Analytics (self-hosted, OSS)
# ============================================
# Matomo UI: https://<PROJECT_HOST>/matomo/
# CHANGE THESE! Use strong, unique passwords
MATOMO_MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_MATOMO_ROOT_PASSWORD_32CHARS
MATOMO_MYSQL_DATABASE=matomo
MATOMO_MYSQL_USER=matomo_prod
MATOMO_MYSQL_PASSWORD=CHANGE_ME_STRONG_MATOMO_DB_PASSWORD_32CHARS
MATOMO_DATABASE_TABLES_PREFIX=matomo_

# Matomo Superuser (created on first start)
# Tip: For SSO auto-linking, keep this in sync with the Authentik username (default: admin)
MATOMO_SUPERUSER_LOGIN=admin
MATOMO_SUPERUSER_PASSWORD=CHANGE_ME_STRONG_MATOMO_ADMIN_PASSWORD
MATOMO_SUPERUSER_EMAIL=admin@your-domain.de

# First tracked site (created on first start)
# NOTE: Keep in sync with your real domain + protocol
MATOMO_SITE_NAME=LLARS
MATOMO_SITE_URL=https://llars.your-domain.de
MATOMO_TRUSTED_HOST=llars.your-domain.de

# Optional: override Matomo archiver URL (cron)
MATOMO_ARCHIVE_URL=https://llars.your-domain.de/matomo/

# Matomo SSO (Authentik OIDC, free via RebelOIDC plugin)
MATOMO_OIDC_ENABLED=true
# Set to true to overwrite existing RebelOIDC settings
MATOMO_OIDC_FORCE_CONFIG=false

# Authentik OAuth2 client for Matomo (auto-created by authentik-init)
AUTHENTIK_MATOMO_APP_SLUG=llars-matomo
AUTHENTIK_MATOMO_CLIENT_ID=llars-matomo
AUTHENTIK_MATOMO_CLIENT_SECRET=CHANGE_ME_STRONG_MATOMO_OIDC_CLIENT_SECRET_32CHARS

# Frontend tracking (Vite)
VITE_MATOMO_ENABLED=true
VITE_MATOMO_BASE_URL=/matomo/
VITE_MATOMO_SITE_ID=1
VITE_MATOMO_SET_USER_ID=true
VITE_MATOMO_TRACK_CLICKS=true
VITE_MATOMO_INCLUDE_QUERY=false
# In production you likely need consent/cookie handling (GDPR). Default to false here to avoid blocking tracking without a CMP.
VITE_MATOMO_REQUIRE_CONSENT=false
VITE_MATOMO_DISABLE_COOKIES=false
VITE_MATOMO_REQUIRE_COOKIE_CONSENT=false

# ============================================
# Authentik Configuration (Identity Provider)
# ============================================
# Django SECRET_KEY - MUST be 50+ characters with high entropy
# CRITICAL: Generate a NEW secret for production!
# Command: openssl rand -base64 64
# DO NOT use the default value below in production!
AUTHENTIK_SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64_MINIMUM_50_CHARS

AUTHENTIK_DB_NAME=authentik_prod
AUTHENTIK_DB_USER=authentik_prod
AUTHENTIK_DB_PASSWORD=CHANGE_ME_STRONG_AUTHENTIK_DB_PASSWORD

# Public URL for Authentik (used for Matomo OIDC redirects)
# Example 1 (separate subdomain): https://auth.your-domain.de
# Example 2 (via nginx path):    https://llars.your-domain.de/authentik
AUTHENTIK_PUBLIC_URL=https://auth.your-domain.de

# Bootstrap Admin (set secure credentials!)
AUTHENTIK_BOOTSTRAP_EMAIL=admin@your-domain.de
AUTHENTIK_BOOTSTRAP_PASSWORD=CHANGE_ME_SECURE_ADMIN_PASSWORD

# OAuth2 Client Configuration
AUTHENTIK_FRONTEND_CLIENT_ID=llars-frontend
AUTHENTIK_BACKEND_CLIENT_ID=llars-backend
# Generate with: openssl rand -hex 32
AUTHENTIK_BACKEND_CLIENT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
AUTHENTIK_ISSUER_URL=http://authentik-server:9000/application/o/llars-backend/

# ============================================
# Optional Features
# ============================================
START_SEEDER=False

# ============================================
# Port Configuration - PRODUCTION
# ============================================
# In production, only nginx ports are exposed!
# Internal services are NOT accessible from outside.
#
# External ports (only nginx exposed via docker-compose.prod.yml)
NGINX_EXTERNAL_PORT=80
# NGINX_EXTERNAL_PORT_SSL=443  # Uncomment when SSL is configured

# These ports are NOT exposed in production (internal only)
FLASK_EXTERNAL_PORT=0
FRONTEND_EXTERNAL_PORT=0
DB_EXTERNAL_PORT=0
AUTHENTIK_EXTERNAL_PORT=0
YJS_EXTERNAL_PORT=0
MKDOCS_EXTERNAL_PORT=0

# Internal ports (container-to-container)
NGINX_INTERNAL_PORT=80
FLASK_INTERNAL_PORT=8081
FRONTEND_INTERNAL_PORT=5173
DB_INTERNAL_PORT=3306
AUTHENTIK_INTERNAL_PORT=9000
AUTHENTIK_DB_INTERNAL_PORT=5432
YJS_INTERNAL_PORT=8082

# ============================================
# Production URLs (after start)
# ============================================
# Frontend:    https://llars.your-domain.de
# Backend API: https://llars.your-domain.de/api
# Authentik:   https://llars.your-domain.de/authentik (via nginx)
# ============================================
