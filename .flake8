[flake8]
# Line length same as black
max-line-length = 120

# Ignore common style issues that don't affect code quality
ignore =
    # E501: line too long (handled by black)
    E501,
    # W503: line break before binary operator (conflicts with W504, PEP8 changed recommendation)
    W503,
    # W504: line break after binary operator
    W504,
    # E226: missing whitespace around arithmetic operator (style preference)
    E226,
    # E402: module level import not at top of file (sometimes needed for path setup)
    E402,
    # E731: do not assign a lambda expression (sometimes useful)
    E731,
    # W391: blank line at end of file (style only)
    W391,
    # E302/E303: blank lines (style only)
    E302,
    E303,
    # E305: expected 2 blank lines after class or function (style only)
    E305,
    # E111/E121/E128: indentation issues (handled by black)
    E111,
    E121,
    E128,
    # E261: spacing before inline comment (style only)
    E261,
    # W291: trailing whitespace (style only)
    W291,
    # E712: comparison to True/False (sometimes intentional)
    E712,
    # E741: ambiguous variable name (context-dependent)
    E741,
    # W605: invalid escape sequence (often false positives in regex)
    W605,
    # F401: imported but unused (many false positives with re-exports)
    F401,
    # F541: f-string without placeholders (often intentional)
    F541,
    # F811: redefinition (often intentional overrides)
    F811,
    # F841: local variable assigned but never used (often intentional)
    F841,
    # F821: undefined name (false positives with lazy imports and type hints)
    F821,
    # F824: global is unused (false positives)
    F824,
    # F403: star import (used intentionally in some modules)
    F403,
    # E114/E122/E124/E126/E129/E131: indentation issues (style only)
    E114,
    E122,
    E124,
    E126,
    E129,
    E131,
    # E203/E225/E231/E241: whitespace issues (style only)
    E203,
    E225,
    E231,
    E241,
    # E711: comparison to None (sometimes intentional for ORM)
    E711,
    # W292/W293: newline/whitespace issues (style only)
    W292,
    W293

# Exclude directories
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    migrations,
    node_modules,
    dist,
    build,
    *.egg-info

# Per-file ignores for test files
per-file-ignores =
    # Test files can have unused imports for fixtures
    test_*.py: F401,F811
    *_test.py: F401,F811
    # Allow unused imports in __init__.py (re-exports)
    __init__.py: F401
