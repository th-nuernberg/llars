        {
          "do": "type",
          "target": "Prompt Name Input",
          "text": "News Summary Eval",
          "speed": "fast"
        },
        {
          "do": "type",
          "target": "input[placeholder='Search and add users...']",
          "text": "ijcai_reviewer_2",
          "speed": "fast"
        },
        {
          "do": "wait",
          "seconds": 1
        },
        {
          "do": "click",
          "target": "ijcai_reviewer_2"
