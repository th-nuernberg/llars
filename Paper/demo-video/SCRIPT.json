        {
          "do": "wait",
          "seconds": 0.5
        },
        {
          "do": "wait_for",
          "target": "Prompt Workspace",
          "timeout": 10
        },
        {
          "do": "click",
          "target": "New Block"
        },
        {
          "do": "wait_for_modal"
        },
        {
          "do": "type",
          "target": "Block Name Input",
          "text": "Role Definition",
          "speed": "fast"
        },
        {
          "do": "click",
          "target": "Block Create Button"
        },
        {
          "do": "wait",
          "seconds": 0.6
        },
        {
          "do": "click",
          "target": "New Block"
        },
        {
          "do": "wait_for_modal"
        },
        {
          "do": "type",
          "target": "Block Name Input",
          "text": "Task Explanation",
          "speed": "fast"
        },
        {
          "do": "click",
          "target": "Block Create Button"
        },
        {
          "do": "wait",
          "seconds": 0.6
        },
        {
          "do": "click",
          "target": "New Block"
        },
        {
          "do": "wait_for_modal"
        },
        {
          "do": "type",
          "target": "Block Name Input",
          "text": "Data Format Explanation",
          "speed": "fast"
        },
        {
          "do": "click",
          "target": "Block Create Button"
        },
        {
          "do": "wait",
          "seconds": 0.6
        }
      ]
    },
    {
      "id": "prompt_eng_4b",
      "speaker": "guest",
      "narration": "So the blocks give structure \u2014 domain experts know where to put what, and developers can enforce a consistent format.",
