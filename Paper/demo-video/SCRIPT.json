{
  "_comment": "Lars Demo Video - IJCAI 2026 Demo Track",
  "_version": "8.0 - With live collaboration demo (two browsers)",
  "_duration_target": "4-5 minutes",
  "_design_principles": [
    "Someone is always speaking",
    "Live collab with a real second browser",
    "Dialogue style: moderator explains, guest asks questions"
  ],

  "config": {
    "url": "http://localhost:55080",
    "resolution": [1920, 1080],
    "tts_model": "custom-small",
    "output_file": "llars_demo.mp4",
    "language": "en",
    "login": {
      "username": "admin",
      "password": "admin123"
    },
    "speakers": {
      "moderator": {
        "name": "Alex",
        "macos_voice": "Fred",
        "macos_rate": 175,
        "description": "A friendly American tech presenter"
      },
      "guest": {
        "name": "David",
        "macos_voice": "Daniel",
        "macos_rate": 150,
        "description": "A distinguished British observer"
      }
    }
  },

  "steps": [
    {
      "_section": "=== INTRO (25s) ===",
      "id": "intro_1",
      "speaker": "moderator",
      "narration": "Hi everyone, I'm Alex.",
      "actions": [
        {"do": "show_title", "title": "Lars", "subtitle": "LLM Assisted Research System"}
      ]
    },

    {
      "id": "intro_2",
      "speaker": "guest",
      "narration": "Hey, I'm David.",
      "actions": [
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "intro_3",
      "speaker": "moderator",
      "narration": "Today I'm giving David a quick tour of Lars, our LLM Assisted Research System.",
      "actions": [
        {"do": "wait", "seconds": 1}
      ]
    },

    {
      "id": "intro_4",
      "speaker": "guest",
      "narration": "Great. If I'm building an application, how do I choose the right model, evaluate what I use today, and prove that a smaller, cheaper option can replace it?",
      "actions": [
        {"do": "wait", "seconds": 1}
      ]
    },

    {
      "_section": "=== PROMPT ENGINEERING (120s) ===",
      "id": "prompt_eng_1",
      "speaker": "moderator",
      "narration": "We start with Prompt Engineering. This is where teams build and refine their prompts together.",
      "actions": [
        {"do": "sync", "after": "Prompt Engineering"},
        {"do": "highlight", "target": "Prompt Engineering", "duration": 1.5},
        {"do": "click", "target": "Prompt Engineering"}
      ]
    },

    {
      "id": "prompt_eng_2",
      "speaker": "moderator",
      "narration": "Let's create a fresh prompt and share it with our researcher so they can jump in immediately.",
      "actions": [
        {"do": "wait", "seconds": 0.5},
        {"do": "highlight", "target": "New Prompt", "duration": 1.5},
        {"do": "click", "target": "New Prompt"},
        {"do": "wait_for_modal"}
      ]
    },

    {
      "id": "prompt_eng_3",
      "speaker": "moderator",
      "narration": "I give it a name, add the researcher, and create the prompt.",
      "actions": [
        {"do": "type", "target": "Prompt Name Input", "text": "Analyst Summary Prompt", "speed": "fast"},
        {"do": "type", "target": "input[placeholder='Search and add users...']", "text": "researcher", "speed": "fast"},
        {"do": "wait", "seconds": 1},
        {"do": "click", "target": "researcher"},
        {"do": "click", "target": "Dialog Create Button"},
        {"do": "wait", "seconds": 1.5}
      ]
    },

    {
      "id": "prompt_eng_3b",
      "speaker": "moderator",
      "narration": "Now we open it and start structuring the blocks.",
      "actions": [
        {"do": "goto", "url": "/promptengineering"},
        {"do": "wait", "seconds": 1},
        {"do": "highlight", "target": "Analyst Summary Prompt", "duration": 1.5},
        {"do": "click", "target": "Analyst Summary Prompt"},
        {"do": "wait", "seconds": 1}
      ]
    },

    {
      "id": "prompt_eng_4",
      "speaker": "moderator",
      "narration": "Prompts are built from blocks. I'll add a System block and a User block.",
      "actions": [
        {"do": "wait", "seconds": 0.5},
        {"do": "click", "target": "New Block"},
        {"do": "wait_for_modal"},
        {"do": "type", "target": "Block Name Input", "text": "System", "speed": "fast"},
        {"do": "click", "target": "Block Create Button"},
        {"do": "wait", "seconds": 0.5},
        {"do": "click", "target": "New Block"},
        {"do": "wait_for_modal"},
        {"do": "type", "target": "Block Name Input", "text": "User", "speed": "fast"},
        {"do": "click", "target": "Block Create Button"},
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "prompt_eng_5",
      "speaker": "moderator",
      "narration": "Now we start writing. The system block defines behavior, the user block carries variables.",
      "actions": [
        {"do": "wait", "seconds": 0.5},
        {"do": "type", "target": "First Block Editor", "text": "You are a careful evaluator. Keep outputs concise and factual.", "speed": "fast"},
        {"do": "type", "target": "Last Block Editor", "text": "\n\nSummarize:\nTitle: {{title}}\nContent: {{content}}", "speed": "fast"}
      ]
    },

    {
      "id": "prompt_eng_5a",
      "speaker": "moderator",
      "narration": "Before testing, I'll add reusable variables with example values.",
      "actions": [
        {"do": "wait", "seconds": 0.5},
        {"do": "click", "target": "Manage Variables"},
        {"do": "wait_for_modal"},
        {"do": "type", "target": "Variable Name Input", "text": "title", "speed": "fast"},
        {"do": "type", "target": "Variable Content Input", "text": "New AI model breaks summarization benchmarks.", "speed": "fast"},
        {"do": "click", "target": "Create Variable"},
        {"do": "wait", "seconds": 0.5},
        {"do": "clear", "target": "Variable Name Input"},
        {"do": "clear", "target": "Variable Content Input"},
        {"do": "type", "target": "Variable Name Input", "text": "content", "speed": "fast"},
        {"do": "type", "target": "Variable Content Input", "text": "Researchers released a smaller model that matches larger systems on key tasks.", "speed": "fast"},
        {"do": "click", "target": "Create Variable"},
        {"do": "wait", "seconds": 0.5},
        {"do": "click", "target": "Variable Dialog Close"},
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "prompt_eng_5b",
      "speaker": "moderator",
      "narration": "Now we can test the prompt instantly.",
      "actions": [
        {"do": "click", "target": "Test"},
        {"do": "wait_for", "target": "Test Prompt Dialog", "timeout": 10},
        {"do": "wait", "seconds": 2},
        {"do": "highlight", "target": "Response Output", "duration": 2},
        {"do": "click", "target": "Close"},
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "prompt_eng_6",
      "speaker": "guest",
      "narration": "Can multiple people edit this at the same time?",
      "actions": [
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "_comment": "=== LIVE COLLAB DEMO (NEW PROMPT) ===",
      "id": "collab_1",
      "speaker": "moderator",
      "narration": "Absolutely. I'm opening a second browser as our researcher colleague.",
      "actions": [
        {"do": "sync", "after": "second browser"},
        {"do": "collab_open", "user": "researcher"},
        {"do": "wait", "seconds": 1}
      ]
    },

    {
      "id": "collab_2",
      "speaker": "moderator",
      "narration": "They open the prompt we just created. Watch the editor.",
      "actions": [
        {"do": "collab_goto", "url": "/promptengineering"},
        {"do": "wait", "seconds": 1},
        {"do": "collab_click", "target": "Analyst Summary Prompt"},
        {"do": "wait", "seconds": 1}
      ]
    },

    {
      "id": "collab_3",
      "speaker": "moderator",
      "narration": "A second cursor appears, and edits sync instantly.",
      "actions": [
        {"do": "collab_focus"},
        {"do": "wait", "seconds": 0.5},
        {"do": "collab_type", "target": "First Block Editor", "text": "\n\n# Added by researcher", "delay": 0.1},
        {"do": "wait", "seconds": 0.5},
        {"do": "highlight", "target": "First Block Editor", "duration": 1.5}
      ]
    },

    {
      "id": "collab_4",
      "speaker": "guest",
      "narration": "Like Google Docs for prompts. That's genuinely useful for distributed research teams.",
      "actions": [
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "prompt_eng_12",
      "speaker": "moderator",
      "narration": "While we collaborate, I can even change my collaboration color right from the app bar.",
      "actions": [
        {"do": "click", "target": ".user-menu-trigger"},
        {"do": "click", "target": "Settings"},
        {"do": "wait", "seconds": 0.5},
        {"do": "highlight", "target": "Collaboration Color", "duration": 1.5},
        {"do": "click_random", "target": "Collab Color Preset", "exclude_selected": true},
        {"do": "wait", "seconds": 0.5},
        {"do": "click", "target": ".v-dialog .v-card-title .v-btn"},
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "prompt_eng_7",
      "speaker": "moderator",
      "narration": "Now let's switch to a prepared prompt seeded by our demo seeder.",
      "actions": [
        {"do": "goto", "url": "/promptengineering"},
        {"do": "wait", "seconds": 1},
        {"do": "highlight", "target": "News Summary Prompt", "duration": 1.5},
        {"do": "click", "target": "News Summary Prompt"},
        {"do": "wait", "seconds": 1}
      ]
    },

    {
      "id": "prompt_eng_8",
      "speaker": "moderator",
      "narration": "The system block defines the AI's role. Two sentences, factual, neutral tone. Very specific instructions.",
      "actions": [
        {"do": "sync", "after": "system block"},
        {"do": "highlight", "target": "First Block Editor", "duration": 3}
      ]
    },

    {
      "id": "prompt_eng_9",
      "speaker": "guest",
      "narration": "And those curly braces in the user block?",
      "actions": [
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "prompt_eng_10",
      "speaker": "moderator",
      "narration": "Variables! Title and content get automatically filled from your data during batch processing. The editor highlights them clearly.",
      "actions": [
        {"do": "sync", "after": "Variables"},
        {"do": "highlight", "target": "Last Block Editor", "duration": 3}
      ]
    },

    {
      "id": "prompt_eng_11",
      "speaker": "moderator",
      "narration": "The researcher can jump in here too.",
      "actions": [
        {"do": "collab_goto", "url": "/promptengineering"},
        {"do": "wait", "seconds": 1},
        {"do": "collab_click", "target": "News Summary Prompt"},
        {"do": "wait", "seconds": 1},
        {"do": "collab_focus"},
        {"do": "collab_type", "target": "Last Block Editor", "text": "\n\n# Reviewer note: keep it under 60 words.", "delay": 0.1},
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "prompt_eng_13",
      "speaker": "moderator",
      "narration": "Prompts are portable too. You can download them or import blocks from JSON.",
      "actions": [
        {"do": "highlight", "target": "Download", "duration": 1.5},
        {"do": "wait", "seconds": 0.5},
        {"do": "highlight", "target": "Import", "duration": 1.5},
        {"do": "collab_close"}
      ]
    },

    {
      "_section": "=== BRING YOUR OWN MODELS (20s) ===",
      "id": "providers_1",
      "speaker": "moderator",
      "narration": "Before generation, you can add your own LLM providers in Settings.",
      "actions": [
        {"do": "goto", "url": "/settings"},
        {"do": "wait", "seconds": 1},
        {"do": "highlight", "target": "User Settings Providers Tab", "duration": 1.5},
        {"do": "click", "target": "User Settings Providers Tab"},
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "providers_2",
      "speaker": "guest",
      "narration": "Does that include OpenAI, Gemini, Claude, and self-hosted endpoints?",
      "actions": [
        {"do": "highlight", "target": "Providers Info", "duration": 1.5}
      ]
    },

    {
      "id": "providers_3",
      "speaker": "moderator",
      "narration": "Yes. OpenAI, Google Gemini, Anthropic Claude, and any OpenAI-compatible endpoint like vLLM or LiteLLM.",
      "actions": [
        {"do": "click", "target": "Add Provider"},
        {"do": "wait_for", "target": "Provider Type Select", "timeout": 10},
        {"do": "click", "target": "Provider Type Select"},
        {"do": "wait", "seconds": 0.5},
        {"do": "highlight", "target": "Provider Type Options", "duration": 2},
        {"do": "click", "target": "Cancel"},
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "_section": "=== BATCH GENERATION (90s) ===",
      "id": "batch_gen_1",
      "speaker": "moderator",
      "narration": "Once the prompt is ready, we move to Batch Generation. Let's create a new job from our data.",
      "actions": [
        {"do": "goto", "url": "/Home"},
        {"do": "wait", "seconds": 1},
        {"do": "highlight", "target": "Batch Generation", "duration": 1.5},
        {"do": "click", "target": "Batch Generation"}
      ]
    },

    {
      "id": "batch_gen_2",
      "speaker": "moderator",
      "narration": "We start a new generation job.",
      "actions": [
        {"do": "wait", "seconds": 1},
        {"do": "highlight", "target": "New Job", "duration": 1.5},
        {"do": "click", "target": "New Job"},
        {"do": "wait_for", "target": "Generation Wizard", "timeout": 10}
      ]
    },

    {
      "id": "batch_gen_3",
      "speaker": "moderator",
      "narration": "Lars accepts JSON upload or a quick paste. I'll paste the JSON and scroll the raw data.",
      "actions": [
        {"do": "highlight", "target": "Source Upload", "duration": 1.5},
        {"do": "click", "target": "Source Upload"},
        {"do": "wait", "seconds": 0.5},
        {"do": "wait_for", "target": "Manual Data Textarea", "timeout": 10},
        {"do": "highlight", "target": "Manual Data Textarea", "duration": 1.5},
        {"do": "set_text_from_file", "target": "Manual Data Textarea", "file": "data/news_articles.json"},
        {"do": "scroll", "target": "Manual Data Textarea", "amount": 260},
        {"do": "wait", "seconds": 0.3},
        {"do": "scroll", "target": "Manual Data Textarea", "amount": 260},
        {"do": "wait", "seconds": 1},
        {"do": "click", "target": "Next"}
      ]
    },

    {
      "id": "batch_gen_4",
      "speaker": "moderator",
      "narration": "Then we pick two prepared prompts for comparison.",
      "actions": [
        {"do": "wait", "seconds": 1},
        {"do": "highlight", "target": "News Summary Prompt Item", "duration": 1.5},
        {"do": "click", "target": "News Summary Prompt Item"},
        {"do": "wait", "seconds": 0.5},
        {"do": "highlight", "target": "Analyst Summary Prompt Item", "duration": 1.5},
        {"do": "click", "target": "Analyst Summary Prompt Item"},
        {"do": "click", "target": "Next"}
      ]
    },

    {
      "id": "batch_gen_5",
      "speaker": "moderator",
      "narration": "Now we choose two models to compare, for example Mistral and Magistral.",
      "actions": [
        {"do": "wait", "seconds": 1},
        {"do": "click", "target": "First Model"},
        {"do": "wait", "seconds": 0.5},
        {"do": "click", "target": "Second Model"},
        {"do": "click", "target": "Next"}
      ]
    },

    {
      "id": "batch_gen_6",
      "speaker": "moderator",
      "narration": "Give the job a name and review the configuration.",
      "actions": [
        {"do": "clear", "target": "Job Name Input"},
        {"do": "type", "target": "Job Name Input", "text": "Live Collab Batch Job", "speed": "fast"},
        {"do": "click", "target": "Next"}
      ]
    },

    {
      "id": "batch_gen_7",
      "speaker": "moderator",
      "narration": "We create the job, and it starts right away.",
      "actions": [
        {"do": "click", "target": "Create Job"},
        {"do": "wait", "seconds": 2}
      ]
    },

    {
      "id": "batch_gen_8",
      "speaker": "moderator",
      "narration": "While that runs, here's a completed job for comparison.",
      "actions": [
        {"do": "goto", "url": "/generation"},
        {"do": "wait", "seconds": 1},
        {"do": "highlight", "target": "News Summary Demo Job", "duration": 2},
        {"do": "click", "target": "News Summary Demo Job"},
        {"do": "wait", "seconds": 1.5}
      ]
    },

    {
      "id": "batch_gen_9",
      "speaker": "guest",
      "narration": "Ten articles, two prompts, two models. That's forty outputs?",
      "actions": [
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "batch_gen_10",
      "speaker": "moderator",
      "narration": "Exactly! Lars creates all combinations automatically. You can compare how different models perform with identical prompts. The cost is calculated upfront.",
      "actions": [
        {"do": "sync", "after": "combinations"},
        {"do": "wait", "seconds": 2}
      ]
    },

    {
      "id": "batch_gen_11",
      "speaker": "guest",
      "narration": "How do you decide which model did better?",
      "actions": [
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "_section": "=== SCENARIO FROM BATCH (60s) ===",
      "id": "scenario_wizard_1",
      "speaker": "moderator",
      "narration": "From a completed batch, we can open the Scenario Wizard right away.",
      "actions": [
        {"do": "highlight", "target": "Scenario Wizard", "duration": 1.5},
        {"do": "click", "target": "Scenario Wizard"},
        {"do": "wait_for", "target": "Wizard Dialog", "timeout": 10},
        {"do": "wait", "seconds": 1.5}
      ]
    },

    {
      "id": "scenario_wizard_2",
      "speaker": "moderator",
      "narration": "We choose Ranking to compare all four summaries: two prompts by two models.",
      "actions": [
        {"do": "wait", "seconds": 1},
        {"do": "highlight", "target": "Ranking", "duration": 1.5},
        {"do": "click", "target": "Ranking"},
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "scenario_wizard_3",
      "speaker": "moderator",
      "narration": "The name is prefilled from the batch. We move to configuration.",
      "actions": [
        {"do": "wait", "seconds": 0.5},
        {"do": "click", "target": "Next"}
      ]
    },

    {
      "id": "scenario_wizard_4",
      "speaker": "moderator",
      "narration": "Default ranking buckets are fine for this demo.",
      "actions": [
        {"do": "wait", "seconds": 0.5},
        {"do": "click", "target": "Next"}
      ]
    },

    {
      "id": "scenario_wizard_5",
      "speaker": "moderator",
      "narration": "We add an admin as a human evaluator, and two LLM evaluators: Mistral and Magistral.",
      "actions": [
        {"do": "wait", "seconds": 0.5},
        {"do": "wait_for", "target": "User List", "timeout": 10},
        {"do": "highlight", "target": "Admin User", "duration": 1.5},
        {"do": "click", "target": "Admin User"},
        {"do": "wait", "seconds": 0.5},
        {"do": "wait_for", "target": "LLM List", "timeout": 10},
        {"do": "click_index", "target": "LLM List", "index": 0},
        {"do": "wait", "seconds": 0.5},
        {"do": "click_index", "target": "LLM List", "index": 1},
        {"do": "wait", "seconds": 0.5},
        {"do": "click", "target": "Next"}
      ]
    },

    {
      "id": "scenario_wizard_6",
      "speaker": "moderator",
      "narration": "And we create the scenario.",
      "actions": [
        {"do": "wait", "seconds": 0.5},
        {"do": "click", "target": "Create Scenario"},
        {"do": "wait_for", "target": "Scenario Workspace", "timeout": 60},
        {"do": "wait", "seconds": 2}
      ]
    },

    {
      "_section": "=== SCENARIO MANAGER (45s) ===",
      "id": "scenario_1",
      "speaker": "moderator",
      "narration": "We land directly in the Scenario Workspace for the batch we just turned into a scenario.",
      "actions": [
        {"do": "wait", "seconds": 0.5},
        {"do": "highlight", "target": "Scenario Tabs", "duration": 1.5}
      ]
    },

    {
      "id": "scenario_2",
      "speaker": "moderator",
      "narration": "Overview gives you progress, evaluators, and live status at a glance.",
      "actions": [
        {"do": "wait", "seconds": 1},
        {"do": "click", "target": "Scenario Tab Overview"},
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "scenario_3",
      "speaker": "guest",
      "narration": "Rating, ranking, comparison. Quite a variety.",
      "actions": [
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "scenario_4",
      "speaker": "moderator",
      "narration": "Tabs keep data, evaluation, and team settings organized in one place.",
      "actions": [
        {"do": "sync", "after": "paradigms"},
        {"do": "highlight", "target": "Scenario Tabs", "duration": 2}
      ]
    },

    {
      "id": "scenario_5",
      "speaker": "guest",
      "narration": "And the evaluators? All human experts?",
      "actions": [
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "scenario_6",
      "speaker": "moderator",
      "narration": "That's the beauty! You can use human experts, LLM evaluators, or both. Compare human ratings against AI evaluations to validate your approach.",
      "actions": [
        {"do": "sync", "after": "evaluators"},
        {"do": "highlight", "target": "Scenario LLM Progress", "duration": 2}
      ]
    },

    {
      "id": "scenario_7",
      "speaker": "moderator",
      "narration": "Let's continue right here with the scenario that came from the batch.",
      "actions": [
        {"do": "wait", "seconds": 0.5},
        {"do": "highlight", "target": "Scenario Tabs", "duration": 1.5}
      ]
    },

    {
      "id": "scenario_8",
      "speaker": "moderator",
      "narration": "Inside the workspace, we can move across the tabs: Overview, Data, Evaluation, and Team.",
      "actions": [
        {"do": "highlight", "target": "Scenario Tabs", "duration": 1.5},
        {"do": "click", "target": "Scenario Tab Data"},
        {"do": "wait", "seconds": 0.5},
        {"do": "click", "target": "Scenario Tab Evaluation"},
        {"do": "wait", "seconds": 0.5},
        {"do": "click", "target": "Scenario Tab Team"},
        {"do": "wait", "seconds": 0.5},
        {"do": "click", "target": "Scenario Tab Overview"},
        {"do": "wait", "seconds": 0.5}
      ]
    },

    {
      "id": "scenario_9",
      "speaker": "moderator",
      "narration": "The live badge and progress bars show LLM evaluators working in real time.",
      "actions": [
        {"do": "highlight", "target": "Scenario Live Badge", "duration": 1.5},
        {"do": "highlight", "target": "Scenario LLM Progress", "duration": 1.5}
      ]
    },

    {
      "id": "scenario_10",
      "speaker": "moderator",
      "narration": "On Evaluation, metrics and results update as soon as new ratings arrive.",
      "actions": [
        {"do": "click", "target": "Scenario Tab Evaluation"},
        {"do": "wait", "seconds": 1},
        {"do": "highlight", "target": "Evaluation Summary", "duration": 1.5},
        {"do": "highlight", "target": "Evaluation Progress", "duration": 1.5}
      ]
    },

