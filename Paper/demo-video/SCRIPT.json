          "do": "sync",
          "after": "Prompt Engineering"
        },
        {
          "do": "highlight",
          "target": "Prompt Engineering",
          "duration": 1.5
        },
        {
          "do": "click",
          "target": "Prompt Engineering"
        }
      ]
    },
    {
      "id": "prompt_eng_2",
      "speaker": "moderator",
      "narration": "Let's create a new prompt. You can add collaborators here \u2014 and we'll add an IJCAI reviewer now.",
      "actions": [
