        {
          "do": "highlight",
          "target": "First Block Editor",
          "duration": 1.2
        },
        {
          "do": "highlight",
          "target": "Last Block Editor",
          "duration": 1.2
        }
      ]
    },
    {
      "id": "prompt_eng_5",
      "speaker": "moderator",
      "narration": "Exactly. Now I'll fill each block: role definition, task explanation, and a data format explanation with input placeholders and output requirements.",
      "actions": [
        {
          "do": "wait",
          "seconds": 0.3
        },
        {
          "do": "type",
          "target": ".editor-block:nth-child(1) .ql-editor",
          "text": "Role definition: You are an analytical journalist who provides thorough context alongside factual reporting.",
          "speed": "fast"
        },
        {
          "do": "type",
          "target": ".editor-block:nth-child(2) .ql-editor",
          "text": "Task explanation: Write a 3-sentence summary of the article. Include relevant background, mention key stakeholders, and explain broader implications beyond the headline.",
          "speed": "fast"
        },
        {
          "do": "type",
          "target": ".editor-block:nth-child(3) .ql-editor",
          "text": "Data format explanation:\nInput:\nTitle: {{title}}\n\nArticle:\n{{content}}\n\nOutput:\nExactly 3 sentences in plain text. No bullet points. No extra commentary.",
          "speed": "fast"
        }
      ]
    },
    {
      "id": "prompt_eng_5a",
      "speaker": "moderator",
      "narration": "Now I define the variables with example values for testing.",
