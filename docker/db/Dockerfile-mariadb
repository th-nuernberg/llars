# Basis-Image auswählen
FROM public.ecr.aws/docker/library/mariadb:11.2.2
LABEL authors="philippsteigerwald"

# Umgebungsvariablen setzen
#ENV MYSQL_ROOT_PASSWORD=meinPasswort
#ENV MYSQL_DATABASE=ki_assistenz_db
#ENV MYSQL_USER=ki_assistenz_user
#ENV MYSQL_PASSWORD=ki_assistenz_pass
# Add healthcheck script
COPY ./docker/db/healthcheck.sh /usr/local/bin/healthcheck.sh
RUN chmod +x /usr/local/bin/healthcheck.sh

# Reduce noisy warnings on Docker Desktop (macOS/Windows)
COPY ./docker/db/llars.cnf /etc/mysql/conf.d/llars.cnf

# Schema patches are applied by the backend on startup to avoid initdb failures.

# Standardport freigeben
EXPOSE 3310
