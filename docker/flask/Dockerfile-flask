# /docker/flask/Dockerfile-flask
# syntax=docker/dockerfile:1

# Verwenden eines offiziellen Python-Images als Basis
FROM python:3.10-slim
LABEL authors="philippsteigerwald"

# Setzt das Arbeitsverzeichnis im Container
WORKDIR /app

# Installiert curl und notwendige Systembibliotheken
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Installiert websocat
RUN curl -L https://github.com/vi/websocat/releases/download/v1.8.0/websocat.x86_64-unknown-linux-musl \
    -o /usr/local/bin/websocat && \
    chmod +x /usr/local/bin/websocat

# Erstellt das Verzeichnis für die Modelle
RUN mkdir -p /app/models

# Kopiert die requirements.txt und installiert nur die Abhängigkeiten
COPY app/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

# Kopiert den Rest des Codes
COPY app /app/
# Kopiert das Start-Skript außerhalb des Anwendungs-Verzeichnisses, damit es durch Volumes nicht überschrieben wird
COPY docker/flask/start_flask.sh /usr/local/bin/start_flask.sh
COPY docker/flask/healthcheck.sh /usr/local/bin/healthcheck.sh
RUN chmod +x /usr/local/bin/start_flask.sh
RUN chmod +x /usr/local/bin/healthcheck.sh

# Setzt die benötigten Umgebungsvariablen für Flask
ENV FLASK_APP=main.py

# Definiert den Startbefehl für den Container
CMD ["/usr/local/bin/start_flask.sh"]
