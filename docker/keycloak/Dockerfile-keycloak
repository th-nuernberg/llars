FROM quay.io/keycloak/keycloak:26.0.7

# Arbeitsverzeichnis setzen
WORKDIR /opt/keycloak

# Wechsle zu root für Setup
USER root

# Installiere Python für Konfigurationsskript
RUN microdnf install -y python3 && microdnf clean all

# Erstelle Verzeichnis für Realm-Import
RUN mkdir -p /opt/keycloak/data/import && \
    mkdir -p /opt/keycloak/import-config && \
    chown -R 1000:1000 /opt/keycloak/data && \
    chown -R 1000:1000 /opt/keycloak/import-config

# Kopiere Konfigurationsskripte
COPY --chmod=755 docker/keycloak/start-keycloak.sh /opt/keycloak/start-keycloak.sh
COPY --chmod=644 docker/keycloak/configure-realm.py /opt/keycloak/import-config/configure-realm.py

# Setze Ownership
RUN chown 1000:1000 /opt/keycloak/start-keycloak.sh && \
    chown 1000:1000 /opt/keycloak/import-config/configure-realm.py

# Keycloak Build für Production (optional, wird durch start-keycloak.sh gesteuert)
# RUN /opt/keycloak/bin/kc.sh build

# Wechsle zurück zu keycloak user
USER 1000

# Expose Port
EXPOSE 8080

# Setze Entrypoint zum neuen Startup-Script
ENTRYPOINT ["/opt/keycloak/start-keycloak.sh"]
