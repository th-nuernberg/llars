# ============================================
# MkDocs Documentation Server
# ============================================
# Lightweight Alpine-based image for minimal resource usage
# Dev mode: Hot-reload with mkdocs serve
# Prod mode: Pre-built static files served by nginx

FROM python:3.12-alpine

WORKDIR /docs

# Install mkdocs and required plugins (no cache for smaller image)
RUN pip install --no-cache-dir \
    mkdocs==1.6.1 \
    mkdocs-material==9.5.44 \
    pymdown-extensions==10.12 \
    mkdocs-mermaid2-plugin==1.1.1

# Install wget for healthcheck
RUN apk add --no-cache wget

# Copy healthcheck script
COPY docker/mkdocs/healthcheck.sh /usr/local/bin/healthcheck.sh
RUN chmod +x /usr/local/bin/healthcheck.sh

# Expose port for mkdocs serve
EXPOSE 8000

# Default command: serve with hot-reload
CMD ["mkdocs", "serve", "--dev-addr=0.0.0.0:8000"]
