FROM public.ecr.aws/docker/library/nginx:alpine

# Copy all nginx configs (entrypoint selects based on PROJECT_STATE and SSL certs)
COPY docker/nginx/nginx.conf /etc/nginx/nginx.dev.conf
COPY docker/nginx/nginx.prod.conf /etc/nginx/nginx.prod.conf
COPY docker/nginx/nginx.prod-no-ssl.conf /etc/nginx/nginx.prod-no-ssl.conf

# Copy entrypoint script
COPY docker/nginx/docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

# Copy error pages and assets
COPY docker/nginx/50x/50x.html /usr/share/nginx/html/50x.html
COPY docker/nginx/50x/50x.css /usr/share/nginx/html/50x-assets/50x.css
COPY docker/nginx/50x/50x.js /usr/share/nginx/html/50x-assets/50x.js
COPY docker/nginx/50x/assets /usr/share/nginx/html/50x-assets/assets

# Set permissions
RUN chown -R nginx:nginx /usr/share/nginx/html \
    && chmod -R 755 /usr/share/nginx/html \
    && chmod 644 /usr/share/nginx/html/*.html \
    && chmod 644 /usr/share/nginx/html/50x-assets/*.css \
    && chmod 644 /usr/share/nginx/html/50x-assets/*.js

# Use custom entrypoint that selects config based on PROJECT_STATE
ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["nginx", "-g", "daemon off;"]
